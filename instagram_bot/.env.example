# Токен доступа (User Access Token или Page Access Token с нужными правами)
META_ACCESS_TOKEN=your_meta_access_token_here

# Ваш собственный секретный токен для проверки (Verify Token), который вы укажете в настройках Webhook в Meta
META_VERIFY_TOKEN=my_super_secret_verify_token

# ID страницы Instagram (необязательно, но полезно для проверок)
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# Если будете использовать OpenAI для анализа:
OPENAI_API_KEY=your_openai_api_key
