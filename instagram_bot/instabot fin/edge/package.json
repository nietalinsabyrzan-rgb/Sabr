{
  "name": "otbasy-instabot-edge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Edge node: receives Instagram webhooks, posts replies via the Graph API; reply text comes from the internal model server",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "auth": "tsx src/get-token.ts",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
