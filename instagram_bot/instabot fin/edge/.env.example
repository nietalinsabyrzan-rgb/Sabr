# --- Instagram (required) ---
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_WEBHOOK_VERIFY_TOKEN=
IG_APP_SECRET=
# Keep true in production. Set false only for local webhook testing.
WEBHOOK_SIGNATURE_REQUIRED=true
# Instagram Graph API host for comments and DMs through Facebook Login.
IG_GRAPH_HOST=https://graph.facebook.com

# --- Model server (required) ---
# Internal-LAN URL of the model server, e.g. http://10.0.0.5:8080
MODEL_SERVER_URL=
# Must be greater than the model server's GENERATE_TIMEOUT_MS (default 90000)
# so the edge doesn't time out before the model server and retry into in-flight work.
LLM_TIMEOUT_MS=100000

# --- Operations ---
PORT=3000
# Kill switch: set to false to keep acknowledging webhooks but send no replies.
AUTO_REPLY_ENABLED=true
# Where dedup state, the refreshed token, audit logs and dead-letter files live.
DATA_DIR=data
AUDIT_RETENTION_DAYS=90
# Refresh Instagram-Login long-lived tokens when older than this many days.
# Facebook Graph/Page tokens are not refreshed through the Instagram refresh endpoint.
IG_TOKEN_REFRESH_DAYS=7
# Per-user anti-spam guard: max events in the rolling window.
RATE_LIMIT_MAX_EVENTS=8
RATE_LIMIT_WINDOW_MS=600000
# Wait this long for follow-up DM messages before generating one combined reply.
DM_BATCH_DELAY_MS=7000
DM_BATCH_MAX_MESSAGES=5

# --- Only needed for the one-time `npm run auth` token helper ---
IG_APP_ID=
IG_OAUTH_REDIRECT_URI=
